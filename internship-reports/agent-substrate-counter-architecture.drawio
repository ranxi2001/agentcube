        <mxCell id="e12" value="6. DNS lookup" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=block;" parent="1" source="client" target="dns" edge="1">
