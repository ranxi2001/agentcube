        <mxCell id="e8" value="Unix gRPC socket" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;strokeWidth=2;endArrow=block;" parent="1" source="atelet" target="ateom" edge="1">
          <mxGeometry relative="1" as="geometry" />
