        <mxCell id="e10" value="start counter workload" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=2;endArrow=block;" parent="1" source="runsc" target="counter" edge="1">
          <mxGeometry relative="1" as="geometry" />
