  <diagram id="agent-substrate-counter" name="Agent Substrate Counter Architecture">
    <mxGraphModel dx="1183" dy="674" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Agent Substrate 架构图：Counter Actor 从模板预热到按需恢复" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="300" y="20" width="1200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="核心思想：Kubernetes 只负责预创建 Worker Pod；Actor 是 Substrate 管理的可 checkpoint / restore 的应用实例，运行在 Worker Pod 内的 gVisor sandbox 中。" style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="240" y="60" width="1320" height="35" as="geometry" />
        </mxCell>
        <mxCell id="lane-user" value="用户 / 开发者入口" style="swimlane;html=1;rounded=1;startSize=28;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="120" width="260" height="880" as="geometry" />
        </mxCell>
        <mxCell id="lane-network" value="网络入口层" style="swimlane;html=1;rounded=1;startSize=28;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="330" y="120" width="270" height="880" as="geometry" />
        </mxCell>
        <mxCell id="lane-control" value="Substrate 控制面" style="swimlane;html=1;rounded=1;startSize=28;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="630" y="120" width="350" height="880" as="geometry" />
        </mxCell>
        <mxCell id="obs" value="Observability&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;logs / metrics / traces&lt;br&gt;Prometheus + OTel + Jaeger&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" parent="lane-control" vertex="1">
          <mxGeometry x="65" y="740" width="210" height="80" as="geometry" />
        </mxCell>
        <mxCell id="lane-k8s" value="Kubernetes 控制面 / API 资源" style="swimlane;html=1;rounded=1;startSize=28;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1010" y="120" width="300" height="880" as="geometry" />
        </mxCell>
        <mxCell id="lane-node" value="Kubernetes Node / Worker Pod" style="swimlane;html=1;rounded=1;startSize=28;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1340" y="120" width="420" height="880" as="geometry" />
        </mxCell>
        <mxCell id="dev" value="开发者 / 平台管理员&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;定义 WorkerPool、ActorTemplate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="170" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="kubectl" value="kubectl-ate / SDK&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;create / resume / suspend / logs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="285" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="client" value="Counter 用户请求&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Host: my-counter-1.actors.resources.substrate.ate.dev&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="430" width="180" height="85" as="geometry" />
        </mxCell>
        <mxCell id="dns" value="atenet-dns + CoreDNS&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;actor DNS suffix -&gt; router Service IP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="370" y="180" width="190" height="75" as="geometry" />
        </mxCell>
        <mxCell id="router" value="atenet-router&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Envoy + ext_proc + xDS&lt;br&gt;解析 actor_id 并触发 ResumeActor&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="370" y="410" width="190" height="95" as="geometry" />
        </mxCell>
        <mxCell id="api" value="ate-api-server&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Actor 生命周期、调度、状态机&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="695" y="270" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="redis" value="Redis / ValKey&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;actor:&amp;lt;id&amp;gt;&lt;br&gt;worker:&amp;lt;ns:pool:pod&amp;gt;&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="690" y="420" width="230" height="95" as="geometry" />
        </mxCell>
        <mxCell id="controller" value="atecontroller&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;WorkerPool -&gt; Deployment&lt;br&gt;ActorTemplate -&gt; Golden Snapshot&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="695" y="620" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="crds" value="CRDs&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;WorkerPool&lt;br&gt;ActorTemplate(counter)&lt;br&gt;SandboxConfig(gvisor)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="1050" y="165" width="220" height="105" as="geometry" />
        </mxCell>
        <mxCell id="k8sapi" value="Kubernetes API Server&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;CRD、Deployment、Pod、Service&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="1050" y="315" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="podcert" value="PodCertificate Controller&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;服务证书 / 身份凭据&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="1050" y="460" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="deploy" value="Deployment / Service&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;WorkerPool 生成 worker Deployment&lt;br&gt;atenet-router / ate-api / ValKey 等系统组件&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="1050" y="625" width="220" height="95" as="geometry" />
        </mxCell>
        <mxCell id="atelet" value="atelet DaemonSet&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;节点级 supervisor&lt;br&gt;准备 OCI bundle / snapshot&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="1380" y="175" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="storage" value="Snapshot Storage&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;GCS / S3 / RustFS&lt;br&gt;golden + latest snapshots&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="1580" y="170" width="150" height="100" as="geometry" />
        </mxCell>
        <mxCell id="workerpod" value="Worker Pod&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Kubernetes 只看到这个 Pod&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="1390" y="390" width="320" height="390" as="geometry" />
        </mxCell>
        <mxCell id="ateom" value="ateom-gvisor 容器&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;常驻进程，监听 Unix socket&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="1430" y="445" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="runsc" value="runsc / gVisor sandbox&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;由 ateom 调用 create/start/restore&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="1430" y="545" width="240" height="75" as="geometry" />
        </mxCell>
        <mxCell id="counter" value="Actor: my-counter-1&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;counter HTTP server&lt;br&gt;内存 requestCount + 文件状态&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;shadow=1;" parent="1" vertex="1">
          <mxGeometry x="1430" y="650" width="240" height="85" as="geometry" />
        </mxCell>
        <mxCell id="note1" value="① 安装 / 配置阶段&lt;br&gt;WorkerPool 让 Kubernetes 预先创建空闲 Worker Pod；ActorTemplate(counter) 触发 golden snapshot 预热。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="60" y="1040" width="390" height="70" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="② 首次请求 my-counter-1&lt;br&gt;请求先到 atenet-router；router 调用 ResumeActor；ateapi 找空闲 worker；atelet/ateom 用 runsc 从 golden snapshot 恢复 counter。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="480" y="1040" width="480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="note3" value="③ 运行与挂起&lt;br&gt;Worker Pod 同一时刻最多承载 1 个 Actor。Suspend 时 checkpoint 到 GCS/S3 并释放 Worker，后续请求可恢复 latest snapshot。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="990" y="1040" width="450" height="70" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="图例：蓝色=Substrate 控制面；紫色=网络入口；绿色=Kubernetes API/资源；黄色=节点/运行时/存储；红色=具体 Counter Actor workload。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1470" y="1040" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="1. apply CRDs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=block;" parent="1" source="dev" target="crds" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="2. watch / reconcile" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=block;" parent="1" source="controller" target="crds" edge="1">
          <mxGeometry relative="1" as="geometry">
