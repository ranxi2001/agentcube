        <mxCell id="e9" value="runsc create / restore" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;" parent="1" source="ateom" target="runsc" edge="1">
          <mxGeometry relative="1" as="geometry" />
