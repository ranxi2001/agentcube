flowchart LR
    accTitle: PR 387 warm-pool data flow before and after the agent-sandbox upgrade
    accDescr: The old v0.1.1 path adopts a pre-warmed Pod and creates a Sandbox with the Claim name. The new v0.4.6 path adopts a pre-warmed Sandbox with a different runtime identity, publishes that name through Claim status, and preserves the Claim identity in Store for deletion.

    subgraph BEFORE["更新前 | agent-sandbox v0.1.1"]
        direction TB
        B_REQ["Client / SDK<br/>创建 CodeInterpreter session"]:::source
        B_WM["WorkloadManager<br/>创建 SandboxClaim<br/>监听同名 Sandbox"]:::legacy
        B_POOL["SandboxWarmPool<br/>预创建并维护 Pod"]:::controller
        B_ADOPT["SandboxClaim controller<br/>adopt 预热 Pod<br/>创建同名 Sandbox"]:::controller
        B_RUNTIME["Sandbox / Claim 同名<br/>annotation 指向 adopted Pod"]:::runtime
        B_READY["Sandbox informer<br/>等待同名对象 Ready"]:::legacy
        B_STORE[("Store + response<br/>Name = Claim = Sandbox<br/>ID / EntryPoints 来自 runtime")]:::state
        B_DELETE["Delete / GC<br/>删除 SandboxClaim<br/>级联清理 runtime<br/>新建 replacement Pod"]:::lifecycle

        B_REQ -->|create session| B_WM
        B_WM -->|create Claim| B_ADOPT
        B_POOL -.->|提供 ready Pod| B_ADOPT
        B_ADOPT -->|name = Claim.name| B_RUNTIME
        B_RUNTIME -->|同名 Ready event| B_READY
        B_WM -.->|预注册 watcher| B_READY
        B_READY -->|Pod IP + 端口探测| B_STORE
        B_STORE -->|按 Claim identity| B_DELETE
    end

    subgraph AFTER["更新后 | PR #387 · agent-sandbox v0.4.6"]
        direction TB
        A_REQ["Client / SDK<br/>创建 CodeInterpreter session"]:::source
        A_WM["WorkloadManager<br/>创建 SandboxClaim<br/>Claim 路径不注册 Sandbox watcher"]:::process
        A_POOL["SandboxWarmPool<br/>预创建 Sandbox → Pod"]:::controller
        A_ADOPT["SandboxClaim controller<br/>adopt 预热 Sandbox<br/>owner: Pool → Claim<br/>名称 / UID 保持不变"]:::controller
        A_READY["Claim 状态桥接 + 就绪等待<br/>status.sandbox.name → live GET Sandbox<br/>Ready=True；2m context 覆盖两次 GET"]:::process
        A_RUNTIME["adopted Sandbox → Pod<br/>annotation / 默认名 → live GET Pod<br/>读取 Pod IP + 探测端口"]:::runtime
        A_STORE[("Store + response<br/>控制身份: Kind / Name = Claim<br/>运行身份: Sandbox UID / Pod EntryPoints")]:::state
        A_DELETE["Delete / GC<br/>删除 SandboxClaim<br/>级联清理 adopted runtime<br/>新建 replacement Sandbox → Pod"]:::lifecycle

        A_REQ -->|create session| A_WM
        A_WM -->|create Claim| A_ADOPT
        A_POOL -.->|选择 ready Sandbox| A_ADOPT
        A_ADOPT -.->|发布 status.sandbox.name| A_READY
        A_READY -->|adopted Sandbox| A_RUNTIME
        A_RUNTIME -->|runtime fields| A_STORE
        A_STORE -->|按 Claim identity| A_DELETE
    end

    B_REQ ~~~ A_REQ

    classDef source fill:#dae8fc,stroke:#6c8ebf,color:#172554;
    classDef process fill:#dbeafe,stroke:#3b82f6,color:#172554;
    classDef controller fill:#d5e8d4,stroke:#82b366,color:#14532d;
    classDef runtime fill:#fff2cc,stroke:#d6b656,color:#713f12;
    classDef state fill:#e1d5e7,stroke:#9673a6,color:#4c1d5f;
    classDef lifecycle fill:#f5f5f5,stroke:#666666,color:#262626;
