<mxfile host="drawio" version="30.2.4" type="device">
  <diagram id="day30-pr387-warm-pool-dataflow" name="PR387 Warm Pool Dataflow Before After">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2860" pageHeight="1680" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="PR #387 Warm Pool Adoption 数据流：升级前后 Pod / Agent 创建删除变化" style="text;html=1;strokeColor=none;fillColor=none;fontSize=26;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="330" y="20" width="2200" height="45" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="核心变化：direct Sandbox watcher 只适用于旧直连路径；warm-pool 路径必须通过 SandboxClaim.status.sandbox.name 找到 adopted Sandbox，再解析 Pod / Agent endpoint，并在 Store 中保留 claim 身份用于删除。" style="text;html=1;strokeColor=none;fillColor=none;fontSize=13;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="260" y="70" width="2340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="old-label" value="升级前 / 旧理解：direct Sandbox 与 runtime 身份基本同名" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="40" y="125" width="1270" height="42" as="geometry" />
        </mxCell>
        <mxCell id="new-label" value="升级后 / #387：SandboxClaim adoption，控制身份与运行身份分离" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="1380" y="125" width="1440" height="42" as="geometry" />
        </mxCell>

        <mxCell id="old-router-lane" value="请求入口 / Router" style="swimlane;html=1;rounded=1;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="40" y="185" width="210" height="940" as="geometry" />
        </mxCell>
        <mxCell id="old-wm-lane" value="WorkloadManager / Store" style="swimlane;html=1;rounded=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="270" y="185" width="270" height="940" as="geometry" />
        </mxCell>
        <mxCell id="old-watch-lane" value="AgentCube watcher" style="swimlane;html=1;rounded=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="570" y="185" width="230" height="940" as="geometry" />
        </mxCell>
        <mxCell id="old-k8s-lane" value="agent-sandbox / Kubernetes" style="swimlane;html=1;rounded=1;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="830" y="185" width="250" height="940" as="geometry" />
        </mxCell>
        <mxCell id="old-runtime-lane" value="Runtime Pod / Agent" style="swimlane;html=1;rounded=1;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1110" y="185" width="200" height="940" as="geometry" />
        </mxCell>

        <mxCell id="old-user" value="用户 / SDK 请求&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;create code interpreter session&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;shadow=1;" parent="old-router-lane" vertex="1">
          <mxGeometry x="25" y="60" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="old-router-create" value="Router&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;无 session id，调用 WM create&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;shadow=1;" parent="old-router-lane" vertex="1">
