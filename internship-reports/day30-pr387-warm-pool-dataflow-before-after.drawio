        </mxCell>
        <mxCell id="old-router-proxy" value="Router reverse proxy&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;只读取 Store EntryPoints&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;shadow=1;" parent="old-router-lane" vertex="1">
          <mxGeometry x="25" y="710" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="old-wm-build" value="build direct Sandbox&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;sandboxName 即 serving Sandbox&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="old-wm-lane" vertex="1">
