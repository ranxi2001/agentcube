        <mxCell id="new-ci-lane" value="CodeInterpreter / Router" style="swimlane;html=1;rounded=1;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1380" y="185" width="250" height="940" as="geometry" />
        </mxCell>
        <mxCell id="new-wm-lane" value="WorkloadManager / Store" style="swimlane;html=1;rounded=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1660" y="185" width="310" height="940" as="geometry" />
        </mxCell>
        <mxCell id="new-claim-lane" value="SandboxClaim controller" style="swimlane;html=1;rounded=1;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="2000" y="185" width="300" height="940" as="geometry" />
        </mxCell>
        <mxCell id="new-runtime-lane" value="adopted Sandbox / Pod" style="swimlane;html=1;rounded=1;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="2330" y="185" width="250" height="940" as="geometry" />
        </mxCell>
        <mxCell id="new-store-lane" value="Router / Delete" style="swimlane;html=1;rounded=1;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="2610" y="185" width="210" height="940" as="geometry" />
        </mxCell>

        <mxCell id="new-ci" value="CodeInterpreter CR&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;warmPoolSize &gt; 0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;shadow=1;" parent="new-ci-lane" vertex="1">
          <mxGeometry x="35" y="55" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="new-ci-reconciler" value="CodeInterpreterReconciler&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;预创建 warm pool 基础设施&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="new-ci-lane" vertex="1">
          <mxGeometry x="35" y="160" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="new-router-create" value="Router create session&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;无 session id，调用 WM&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;shadow=1;" parent="new-ci-lane" vertex="1">
          <mxGeometry x="35" y="420" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="new-router-existing" value="Router existing session&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;从 Store 取 EntryPoints&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;shadow=1;" parent="new-ci-lane" vertex="1">
          <mxGeometry x="35" y="760" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="new-template" value="SandboxTemplate&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;来自 CodeInterpreter template&lt;br&gt;NetworkPolicy unmanaged&lt;br&gt;注入 PicoD public key&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" parent="new-wm-lane" vertex="1">
          <mxGeometry x="35" y="55" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="new-warmpool" value="SandboxWarmPool&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;replicas=N&lt;br&gt;TemplateRef = CodeInterpreter.Name&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="new-wm-lane" vertex="1">
          <mxGeometry x="35" y="190" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="new-build-claim" value="build SandboxClaim&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;claimName = session sandbox name&lt;br&gt;labels: session / owner / ttl&lt;br&gt;ownerRef -&gt; CodeInterpreter&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;shadow=1;" parent="new-wm-lane" vertex="1">
          <mxGeometry x="35" y="400" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="new-store-placeholder" value="Store placeholder&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Kind=SandboxClaim&lt;br&gt;Name=claimName&lt;br&gt;Status=creating&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;" parent="new-wm-lane" vertex="1">
          <mxGeometry x="35" y="555" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="new-wait-claim" value="waitForClaimSandboxReady&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;每 1s poll claim&lt;br&gt;读 status.sandbox.name&lt;br&gt;再 get adopted Sandbox Ready=True&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;shadow=1;" parent="new-wm-lane" vertex="1">
          <mxGeometry x="35" y="690" width="240" height="115" as="geometry" />
        </mxCell>
        <mxCell id="new-store-ready" value="Store ready SandboxInfo&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Name = claimName&lt;br&gt;Kind = SandboxClaim&lt;br&gt;SandboxID = adopted UID&lt;br&gt;EntryPoints = adopted Pod IP&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;" parent="new-wm-lane" vertex="1">
          <mxGeometry x="35" y="835" width="240" height="115" as="geometry" />
        </mxCell>

        <mxCell id="new-claim-resource" value="SandboxClaim&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Spec.TemplateRef.Name = CI&lt;br&gt;per-session control object&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="new-claim-lane" vertex="1">
          <mxGeometry x="35" y="410" width="230" height="95" as="geometry" />
        </mxCell>
        <mxCell id="new-claim-controller" value="SandboxClaimReconciler&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;查 status / assigned label / 同名 cold path&lt;br&gt;再从 warm queue 取 candidate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" parent="new-claim-lane" vertex="1">
          <mxGeometry x="35" y="535" width="230" height="110" as="geometry" />
        </mxCell>
        <mxCell id="new-adopt" value="completeAdoption&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;ownerRef: WarmPool -&gt; Claim&lt;br&gt;patch claim identity labels&lt;br&gt;ensure SandboxPodNameAnnotation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" parent="new-claim-lane" vertex="1">
          <mxGeometry x="35" y="675" width="230" height="120" as="geometry" />
        </mxCell>
        <mxCell id="new-claim-status" value="Claim status update&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;status.sandbox.name = adopted Sandbox&lt;br&gt;status.sandbox.podIPs mirrored&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" parent="new-claim-lane" vertex="1">
          <mxGeometry x="35" y="825" width="230" height="90" as="geometry" />
        </mxCell>

        <mxCell id="new-warm-sandbox" value="pre-warmed Sandbox&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;由 SandboxWarmPool 预先维护&lt;br&gt;请求前已存在&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;shadow=1;" parent="new-runtime-lane" vertex="1">
          <mxGeometry x="25" y="140" width="200" height="95" as="geometry" />
        </mxCell>
        <mxCell id="new-warm-pod" value="warm Pod + PicoD / Agent&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;已经 Running&lt;br&gt;等待 claim adopt&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;" parent="new-runtime-lane" vertex="1">
          <mxGeometry x="25" y="270" width="200" height="95" as="geometry" />
        </mxCell>
        <mxCell id="new-adopted-sandbox" value="adopted Sandbox&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;真实 serving runtime&lt;br&gt;Ready=True&lt;br&gt;name 可能不同于 claim&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;shadow=1;" parent="new-runtime-lane" vertex="1">
          <mxGeometry x="25" y="640" width="200" height="115" as="geometry" />
        </mxCell>
        <mxCell id="new-pod-lookup" value="serving Pod lookup&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;fast path: SandboxPodNameAnnotation&lt;br&gt;fallback: label + ownerRef&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;" parent="new-runtime-lane" vertex="1">
          <mxGeometry x="25" y="790" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="new-probe" value="probe entrypoints&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;PodIP + ports&lt;br&gt;Router 的真实转发目标&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;" parent="new-runtime-lane" vertex="1">
          <mxGeometry x="25" y="925" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="new-router-proxy" value="Router reverse proxy&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;不关心 direct / claim&lt;br&gt;只使用 EntryPoints&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;shadow=1;" parent="new-store-lane" vertex="1">
          <mxGeometry x="25" y="760" width="160" height="95" as="geometry" />
        </mxCell>
        <mxCell id="new-delete" value="Delete / GC&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Kind=SandboxClaim&lt;br&gt;delete SandboxClaim(claimName)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;shadow=1;" parent="new-store-lane" vertex="1">
          <mxGeometry x="25" y="885" width="160" height="95" as="geometry" />
        </mxCell>

        <mxCell id="note-old-identity" value="旧路径关键假设&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;控制对象、运行对象、Pod 查找键基本同名：Sandbox name = serving Sandbox = Pod label / ownerRef。Watcher 按 namespace/name 等 Ready event。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="60" y="1160" width="570" height="110" as="geometry" />
        </mxCell>
        <mxCell id="note-old-risk" value="旧 warm-pool 误区&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;如果把 warm pool 理解成 SandboxWarmPool -&gt; Pod，或把 claim name 当成 serving Sandbox / Pod name，WM 可能 watch 错对象、找错 Pod、删错资源。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="660" y="1160" width="620" height="110" as="geometry" />
        </mxCell>
        <mxCell id="note-new-identity" value="#387 新语义：身份分离&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;控制身份保留 SandboxClaim：Store Name=claimName、Kind=SandboxClaim，delete / GC 删除 claim。运行身份来自 adopted Sandbox / Pod：SandboxID=adopted UID、EntryPoints=Pod IP。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="1400" y="1160" width="660" height="110" as="geometry" />
        </mxCell>
        <mxCell id="note-new-risk" value="仍需关注&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Pod informer cache 可能短暂滞后：adopted Sandbox Ready=True 后，Pod name / IP lookup 如果立刻失败，未来可考虑短 retry 或用 claim.status.sandbox.podIPs 作为 fallback。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="2090" y="1160" width="700" height="110" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="图例：灰色=用户/Router；蓝色=AgentCube 控制面；绿色=agent-sandbox / Kubernetes 资源；黄色=真实 runtime Pod / Agent；紫色=网络转发；红色=删除或错误风险。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="60" y="1300" width="2730" height="60" as="geometry" />
        </mxCell>
        <mxCell id="diff1" value="变化 1：创建对象&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;升级前请求时直接 create Sandbox；升级后 CodeInterpreter 先维护 SandboxTemplate / SandboxWarmPool，请求时只 create SandboxClaim。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="60" y="1390" width="520" height="95" as="geometry" />
        </mxCell>
        <mxCell id="diff2" value="变化 2：Ready 观测&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;direct path 仍 watch Sandbox Ready event；warm path poll SandboxClaim.status.sandbox.name，然后 get adopted Sandbox 并确认 Ready=True。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="610" y="1390" width="560" height="95" as="geometry" />
        </mxCell>
        <mxCell id="diff3" value="变化 3：Pod / Agent 查找&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;旧路径可按 Sandbox name 推断；新路径优先用 adopted Sandbox 的 SandboxPodNameAnnotation，失败才走 label + ownerRef fallback。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="1200" y="1390" width="580" height="95" as="geometry" />
        </mxCell>
        <mxCell id="diff4" value="变化 4：删除 / GC&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;旧路径 delete Sandbox(name)；新路径必须 delete SandboxClaim(claimName)，由 agent-sandbox controller 根据 claim ownership 清理 adopted Sandbox / Pod。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="1810" y="1390" width="580" height="95" as="geometry" />
        </mxCell>
        <mxCell id="diff5" value="变化 5：Router 不感知 adoption&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Router 继续从 Store 读 EntryPoints 并反向代理。只要 WM 写对 Store，data plane 不需要知道 direct Sandbox 还是 warm claim。&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" parent="1" vertex="1">
          <mxGeometry x="2420" y="1390" width="370" height="95" as="geometry" />
        </mxCell>

