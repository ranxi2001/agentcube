          <mxGeometry height="95" width="160" x="25" y="760" as="geometry" />
        </mxCell>
        <mxCell id="new-delete" parent="new-store-lane" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;shadow=1;" value="Delete / GC&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Kind=SandboxClaim&lt;br&gt;delete SandboxClaim(claimName)&lt;/font&gt;" vertex="1">
          <mxGeometry height="95" width="160" x="25" y="885" as="geometry" />
        </mxCell>
        <mxCell id="note-old-identity" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;" value="旧观测关键假设&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;把 SandboxWarmPool 近似看成直接维护 Pod：pool ready、Pod ready、endpoint 可从 pool/claim 标签推断，没有通过 claim.status.sandbox.name 绑定 serving Sandbox。&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="570" x="60" y="1202" as="geometry" />
        </mxCell>
        <mxCell id="note-old-risk" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" value="旧 warm-pool 误区&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;pool update / refill 只能说明容量被补回，不能证明哪个 Sandbox 被 claim adopt。若把 claim name 当 serving Sandbox / Pod name，WM 仍可能 watch 错对象、找错 Pod、删错资源。&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="620" x="660" y="1202" as="geometry" />
        </mxCell>
        <mxCell id="note-new-identity" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="#387 新语义：身份分离&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;控制身份保留 SandboxClaim：Store Name=claimName、Kind=SandboxClaim，delete / GC 删除 claim。运行身份来自 adopted Sandbox / Pod：SandboxID=adopted UID、EntryPoints=Pod IP。&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="660" x="1400" y="1202" as="geometry" />
        </mxCell>
        <mxCell id="note-new-risk" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" value="仍需关注&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Pod informer cache 可能短暂滞后：adopted Sandbox Ready=True 后，Pod name / IP lookup 如果立刻失败，未来可考虑短 retry 或用 claim.status.sandbox.podIPs 作为 fallback。&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="700" x="2090" y="1202" as="geometry" />
        </mxCell>
        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" value="图例：灰色=用户/Router；蓝色=AgentCube 控制面；绿色=agent-sandbox / Kubernetes 资源；黄色=真实 runtime Pod / Agent；紫色=网络转发；红色=删除或错误风险。" vertex="1">
          <mxGeometry height="60" width="2730" x="60" y="1315" as="geometry" />
        </mxCell>
        <mxCell id="diff1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" value="变化 1：创建对象&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;旧观测只看到 SandboxWarmPool 维护 Pod / 补池；新语义明确 warm pool 先维护 pre-warmed Sandbox/Pod，请求时只 create SandboxClaim。&lt;/font&gt;" vertex="1">
          <mxGeometry height="95" width="520" x="60" y="1390" as="geometry" />
        </mxCell>
        <mxCell id="diff2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" value="变化 2：Ready 观测&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;旧 helper 只能看 pool ready 或 Pod ready；warm claim 必须 poll SandboxClaim.status.sandbox.name，然后 get adopted Sandbox 并确认 Ready=True。&lt;/font&gt;" vertex="1">
          <mxGeometry height="95" width="560" x="610" y="1390" as="geometry" />
        </mxCell>
        <mxCell id="diff3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" value="变化 3：Pod / Agent 查找&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;旧观测按 pool/claim label 推断 Pod；新路径优先用 adopted Sandbox 的 SandboxPodNameAnnotation，失败才走 label + ownerRef fallback。&lt;/font&gt;" vertex="1">
          <mxGeometry height="95" width="580" x="1200" y="1390" as="geometry" />
        </mxCell>
        <mxCell id="diff4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" value="变化 4：删除 / GC&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;旧观测下 cleanup 目标容易混淆；新路径必须 delete SandboxClaim(claimName)，由 agent-sandbox controller 根据 claim ownership 清理 adopted Sandbox / Pod。&lt;/font&gt;" vertex="1">
          <mxGeometry height="95" width="580" x="1810" y="1390" as="geometry" />
        </mxCell>
        <mxCell id="diff5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" value="变化 5：Router 不感知 adoption&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Router 继续从 Store 读 EntryPoints 并反向代理。只要 WM 写对 Store，data plane 不需要知道 direct Sandbox 还是 warm claim。&lt;/font&gt;" vertex="1">
          <mxGeometry height="95" width="370" x="2420" y="1390" as="geometry" />
        </mxCell>
