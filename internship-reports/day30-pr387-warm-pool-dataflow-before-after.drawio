        <mxCell id="old-store-placeholder" value="Store placeholder&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Kind=Sandbox&lt;br&gt;Name=sandboxName&lt;br&gt;Status=creating&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;" parent="old-wm-lane" vertex="1">
          <mxGeometry x="35" y="230" width="200" height="95" as="geometry" />
        </mxCell>
        <mxCell id="old-register-watch" value="register WatchSandboxOnce&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;key = namespace / sandboxName&lt;br&gt;必须早于 create&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;shadow=1;" parent="old-wm-lane" vertex="1">
          <mxGeometry x="35" y="370" width="200" height="95" as="geometry" />
        </mxCell>
        <mxCell id="old-wm-ready" value="Update Store ready&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;SandboxID = Sandbox UID&lt;br&gt;EntryPoints = Pod IP:ports&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;" parent="old-wm-lane" vertex="1">
          <mxGeometry x="35" y="600" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="old-delete" value="Delete / GC&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;Kind=Sandbox&lt;br&gt;delete Sandbox(name)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;shadow=1;" parent="old-wm-lane" vertex="1">
          <mxGeometry x="35" y="800" width="200" height="85" as="geometry" />
        </mxCell>

        <mxCell id="old-watch-once" value="SandboxReconciler&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;watch Sandbox Ready=True&lt;br&gt;只关心同名 Sandbox&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;shadow=1;" parent="old-watch-lane" vertex="1">
          <mxGeometry x="25" y="380" width="180" height="95" as="geometry" />
        </mxCell>
        <mxCell id="old-ready-event" value="SandboxStatusUpdate&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;resultChan 返回 ready Sandbox&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;shadow=1;" parent="old-watch-lane" vertex="1">
          <mxGeometry x="25" y="520" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="old-sandbox-cr" value="Sandbox CR&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;name = sandboxName&lt;br&gt;AgentCube 直接创建&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;shadow=1;" parent="old-k8s-lane" vertex="1">
          <mxGeometry x="35" y="115" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="old-as-controller" value="agent-sandbox controller&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;reconcile Sandbox&lt;br&gt;create Pod&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" parent="old-k8s-lane" vertex="1">
          <mxGeometry x="35" y="295" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="old-sandbox-ready" value="Sandbox Ready=True&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;watcher 看到同名对象 Ready&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;shadow=1;" parent="old-k8s-lane" vertex="1">
          <mxGeometry x="35" y="520" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="old-delete-sandbox" value="delete Sandbox&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;K8s ownerRef / controller 清理 Pod&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;shadow=1;" parent="old-k8s-lane" vertex="1">
          <mxGeometry x="35" y="800" width="180" height="85" as="geometry" />
        </mxCell>

        <mxCell id="old-pod" value="Pod + PicoD / Agent&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;通常可按 Sandbox name / label / ownerRef 找到&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;shadow=1;" parent="old-runtime-lane" vertex="1">
          <mxGeometry x="20" y="295" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="old-entrypoints" value="probe entrypoints&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;PodIP + configured ports&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;shadow=1;" parent="old-runtime-lane" vertex="1">
